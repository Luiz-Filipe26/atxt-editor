{
    "name": "atxt-editor",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "test": "node -e \"process.env.NO_COLOR='1'; process.exit(require('child_process').spawnSync('npx', ['vitest', 'run'], {stdio: 'inherit', shell: true}).status || 0)\"",
        "coverage": "node -e \"process.env.NO_COLOR='1'; process.exit(require('child_process').spawnSync('npx', ['vitest', 'run', '--coverage'], {stdio: 'inherit', shell: true}).status || 0)\""
    },
    "devDependencies": {
        "@types/node": "25.5.0",
        "@vitest/coverage-v8": "4.1.2",
        "typescript": "6.0.2",
        "vite": "8.0.7",
        "vite-plugin-singlefile": "2.3.2",
        "vitest": "4.1.2"
    },
    "dependencies": {
        "isomorphic-dompurify": "3.7.1"
    },
    "overrides": {
        "picomatch": "4.0.4"
    }
}
